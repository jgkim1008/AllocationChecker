{
  "functions": {
    "app/api/robo-advisor/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/fibonacci/scan?market=US",
      "schedule": "0 22 * * 1-5"
    },
    {
      "path": "/api/fibonacci/scan?market=KR",
      "schedule": "0 7 * * 1-5"
    },
    {
      "path": "/api/fibonacci/scan?market=INDEX",
      "schedule": "30 7 * * 1-5"
    },
    {
      "path": "/api/strategies/value-scan/run",
      "schedule": "0 0 * * 0"
    },
    {
      "path": "/api/auto-trade/check-fills?action=check&market=domestic",
      "schedule": "35 6 * * 1-5"
    },
    {
      "path": "/api/auto-trade/check-fills?action=check&market=overseas",
      "schedule": "5 21 * * 1-5"
    }
  ]
}
